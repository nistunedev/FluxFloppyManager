<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="Flux Floppy Manager"/>
      <Scaled Value="True"/>
      <ResourceType Value="res"/>
      <UseXPManifest Value="True"/>
      <XPManifest>
        <DpiAware Value="True/PM_V2"/>
        <TextName Value="Flux Floppy Manager"/>
        <TextDesc Value="A GUI for Greaseweazle"/>
      </XPManifest>
      <Icon Value="0"/>
    </General>
    <VersionInfo>
      <UseVersionInfo Value="True"/>
      <MajorVersionNr Value="5"/>
      <MinorVersionNr Value="2"/>
      <RevisionNr Value="7"/>
      <BuildNr Value="2"/>
      <StringTable Comments="Freeware" CompanyName="NistuneDev" FileDescription="Flux Floppy Manager - A GUI for Greaseweazle" InternalName="FluxFloppyManager" LegalCopyright="(c) 2026 NistuneDev" OriginalFilename="FluxFloppyManager.exe" ProductName="Flux Floppy Manager" ProductVersion="5"/>
    </VersionInfo>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <DestinationDirectory Value=""/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="SQLDBLaz"/>
      </Item>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="FluxFloppyManager.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="MainForm.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="FrmMain"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="MainForm">
      </Unit>
      <Unit>
        <Filename Value="AboutDialog.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="FrmAbout"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="AboutDialog">
      </Unit>
      <Unit>
        <Filename Value="OptionsDialog.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="FrmOptions"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="OptionsDialog">
      </Unit>
      <Unit>
        <Filename Value="OperationsDialog.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="FrmOperations"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="OperationsDialog">
      </Unit>      
      <Unit>
        <Filename Value="commonconsts.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="CommonConsts"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="FluxFloppyManager"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <UnitOutputDirectory Value="lib/$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Parsing>
      <SyntaxOptions>
        <IncludeAssertionCode Value="True"/>
      </SyntaxOptions>
    </Parsing>
    <CodeGeneration>
      <Checks>
        <IOChecks Value="True"/>
        <RangeChecks Value="True"/>
        <StackChecks Value="True"/>
      </Checks>
      <VerifyObjMethodCallValidity Value="True"/>
    </CodeGeneration>
    <Linking>
      <Debugging>
        <RunWithoutDebug Value="True"/>
        <DebugInfoType Value="dsDwarf2Set"/>
        <UseExternalDbgSyms Value="True"/>
      </Debugging>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
  </CompilerOptions>
</CONFIG>
